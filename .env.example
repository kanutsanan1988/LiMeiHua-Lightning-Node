# LiMeiHua Lightning Node - Environment Variables
# 
# ชุดซอฟต์แวร์ชุดนี้ มีไว้เพื่อเป็นโครงสร้างพื้นฐานทางการเงินยุคใหม่
# เพื่อรองรับการไหลของเงินจำนวนมหาศาลของท่านผู้เฒ่าหลี่เหมยฮัว หรือ LiMeiHua Grand Mother
# และ source code นี้สร้างโดย Mr.Kanutsanan Pongpanna (นายคณัสนันท์ พงษ์พันนา)
# URL: https://chatgpt.com/g/g-68d289535dec81919445deb9830f2d8e-kanutsanan-pongpanna

# Server Configuration
PORT=3000
NODE_ENV=development

# Lightning Network Configuration
LN_NODE_ALIAS=LiMeiHua Lightning Node
LN_NETWORK=testnet
LN_REST_URL=http://localhost:8080
LN_MACAROON_PATH=/path/to/admin.macaroon
LN_CERT_PATH=/path/to/tls.cert

# Taproot Assets Configuration
TAPROOT_ASSETS_URL=http://localhost:8089
TAPROOT_ASSETS_MACAROON_PATH=/path/to/taproot.macaroon

# Bitcoin Configuration
BITCOIN_NETWORK=testnet
BITCOIN_RPC_URL=http://localhost:18332
BITCOIN_RPC_USER=bitcoin
BITCOIN_RPC_PASSWORD=password

# Database Configuration (Optional)
DATABASE_URL=sqlite:///lightning_node.db

# API Configuration
API_TIMEOUT=30000
API_RETRY_ATTEMPTS=3

# Logging
LOG_LEVEL=info
LOG_FILE=logs/lightning-node.log

# Frontend Configuration
REACT_APP_API_URL=http://localhost:3000
REACT_APP_ENVIRONMENT=development
